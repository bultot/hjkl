# skhd config.
# hyper = caps-lock -> cmd + alt + ctrl (via Raycast). hyper + shift = move layer.
# Based on the stock skhd example with alt swapped for hyper, plus mnemonic space
# keys (p/w/m/a/s/u) and a service sub-mode for the secondary actions (hyper can't
# stack more modifiers, so they live in a mode instead).
#
# Spaces: 1 Personal  2 Work  3 Scheduling  4 Terminal  5 Music  6 Utils
# (space 4's mnemonic key stays 'a' since 't' is taken by the float toggle.)

# ----- focus space (index) -----
cmd + alt + ctrl - 1 : yabai -m space --focus 1
cmd + alt + ctrl - 2 : yabai -m space --focus 2
cmd + alt + ctrl - 3 : yabai -m space --focus 3
cmd + alt + ctrl - 4 : yabai -m space --focus 4
cmd + alt + ctrl - 5 : yabai -m space --focus 5
cmd + alt + ctrl - 6 : yabai -m space --focus 6

# ----- focus space (mnemonics: Personal/Work/scheduling/Ai=Terminal/muSic/Utils) -----
cmd + alt + ctrl - p : yabai -m space --focus 1
cmd + alt + ctrl - w : yabai -m space --focus 2
cmd + alt + ctrl - m : yabai -m space --focus 3
cmd + alt + ctrl - a : yabai -m space --focus 4
cmd + alt + ctrl - s : yabai -m space --focus 5
cmd + alt + ctrl - u : yabai -m space --focus 6

# ----- send focused window to space + follow -----
cmd + alt + ctrl + shift - 1 : yabai -m window --space 1 && yabai -m space --focus 1
cmd + alt + ctrl + shift - 2 : yabai -m window --space 2 && yabai -m space --focus 2
cmd + alt + ctrl + shift - 3 : yabai -m window --space 3 && yabai -m space --focus 3
cmd + alt + ctrl + shift - 4 : yabai -m window --space 4 && yabai -m space --focus 4
cmd + alt + ctrl + shift - 5 : yabai -m window --space 5 && yabai -m space --focus 5
cmd + alt + ctrl + shift - 6 : yabai -m window --space 6 && yabai -m space --focus 6
cmd + alt + ctrl + shift - p : yabai -m window --space 1 && yabai -m space --focus 1
cmd + alt + ctrl + shift - w : yabai -m window --space 2 && yabai -m space --focus 2
cmd + alt + ctrl + shift - m : yabai -m window --space 3 && yabai -m space --focus 3
cmd + alt + ctrl + shift - a : yabai -m window --space 4 && yabai -m space --focus 4
cmd + alt + ctrl + shift - s : yabai -m window --space 5 && yabai -m space --focus 5
cmd + alt + ctrl + shift - u : yabai -m window --space 6 && yabai -m space --focus 6

# ----- focus window within the space (hjkl) -----
cmd + alt + ctrl - h : yabai -m window --focus west
cmd + alt + ctrl - j : yabai -m window --focus south
cmd + alt + ctrl - k : yabai -m window --focus north
cmd + alt + ctrl - l : yabai -m window --focus east

# ----- swap window (hyper + shift + hjkl) -----
cmd + alt + ctrl + shift - h : yabai -m window --swap west
cmd + alt + ctrl + shift - j : yabai -m window --swap south
cmd + alt + ctrl + shift - k : yabai -m window --swap north
cmd + alt + ctrl + shift - l : yabai -m window --swap east

# ----- window / layout -----
cmd + alt + ctrl - f : yabai -m window --toggle zoom-fullscreen
cmd + alt + ctrl - i : $HOME/.local/bin/claude-goto   # jump to the agent that needs you (cycles)
cmd + alt + ctrl - t : yabai -m window --toggle float --grid 4:4:1:1:2:2
cmd + alt + ctrl - g : yabai -m space --toggle gap && yabai -m space --toggle padding   # toggle gaps + padding (zen mode)
cmd + alt + ctrl - 0x32 : yabai -m space --focus recent        # backtick: back-and-forth
cmd + alt + ctrl - y : pgrep -x yabai >/dev/null && yabai --stop-service || yabai --start-service   # toggle yabai on/off

# ----- service sub-mode: resize / rotate / balance / split -----
:: default
:: service @
cmd + alt + ctrl - 0x2B ; service                              # hyper + comma -> enter

service < escape ; default
service < return ; default
service < h : yabai -m window --resize right:-60:0
service < l : yabai -m window --resize right:60:0
service < j : yabai -m window --resize bottom:60:0
service < k : yabai -m window --resize bottom:-60:0
service < b : yabai -m space --balance ; skhd -k "escape"
service < e : yabai -m window --toggle split ; skhd -k "escape"
service < r : yabai -m space --rotate 90 ; skhd -k "escape"
service < f : yabai -m window --toggle zoom-fullscreen ; skhd -k "escape"
service < q : skhd -k "escape"; (yabai --restart-service; skhd --reload) &
